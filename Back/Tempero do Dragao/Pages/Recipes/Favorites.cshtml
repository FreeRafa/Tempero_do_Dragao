@page
@model Tempero_do_Dragao.Pages.Recipes.FavoritesModel
@{
    ViewData["Title"] = "Os meus Favoritos";
}

<style>
    :root {
        --red-deep:  #8B0000;
        --red-mid:   #A31515;
        --cream:     #F5ECD7;
        --cream-dark:#E8D9C0;
        --gold:      #C9A84C;
        --charcoal:  #1A1A1A;
    }

    body { background: #faf7f2; }

    /* ── HEADER ── */
    .page-header {
        background: var(--red-deep);
        padding: 2.5rem 2rem;
        position: relative;
        overflow: hidden;
    }

    .page-header::before {
        content: '❤️';
        position: absolute;
        right: 3rem; top: 50%;
        transform: translateY(-50%);
        font-size: 8rem;
        opacity: 0.08;
    }

    .page-header .tag {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold);
        border: 1px solid rgba(201,168,76,0.4);
        padding: 0.3rem 0.9rem;
        border-radius: 2px;
        margin-bottom: 0.8rem;
    }

    .page-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--cream);
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    .page-header h1 span { color: var(--gold); }

    /* ── CONTENT ── */
    .content-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--charcoal);
    }

    .section-count {
        font-size: 0.8rem;
        color: #999;
    }

    /* ── GRID ── */
    .recipe-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    /* ── CARD ── */
    .recipe-card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
    }

    .recipe-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    }

    .card-img {
        width: 100%;
        height: 160px;
        background: linear-gradient(135deg, var(--red-deep), var(--red-mid));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        position: relative;
    }

    .card-img::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.2));
    }

    .card-badge {
        position: absolute;
        top: 0.8rem;
        right: 0.8rem;
        background: var(--gold);
        color: var(--charcoal);
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border-radius: 3px;
        z-index: 2;
    }

    .card-body { padding: 1.2rem; }

    .card-category {
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--red-mid);
        margin-bottom: 0.3rem;
    }

    .card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--charcoal);
        margin-bottom: 0.3rem;
        line-height: 1.3;
    }

    .card-desc {
        font-size: 0.82rem;
        color: #888;
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.8rem;
        border-top: 1px solid #f0ece6;
    }

    .card-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.75rem;
        color: #aaa;
    }

    /* Remove favorite button */
    .btn-unfavorite {
        background: none;
        border: 1.5px solid #ffcdd2;
        color: var(--red-mid);
        padding: 0.3rem 0.7rem;
        border-radius: 4px;
        font-size: 0.75rem;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.2s;
    }

    .btn-unfavorite:hover {
        background: #ffebee;
    }

    /* Card link */
    .card-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    /* ── EMPTY STATE ── */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: #bbb;
    }

    .empty-state .emoji { font-size: 4rem; margin-bottom: 1rem; }

    .empty-state h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.4rem;
        color: #ccc;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        font-size: 0.88rem;
        font-weight: 300;
        margin-bottom: 1.5rem;
    }

    .btn-explore {
        display: inline-block;
        padding: 0.7rem 1.8rem;
        background: var(--red-deep);
        color: var(--cream);
        text-decoration: none;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        transition: background 0.2s;
    }

    .btn-explore:hover { background: var(--red-mid); color: var(--cream); }

    @@media (max-width: 640px) {
        .recipe-grid { grid-template-columns: 1fr; }
    }
</style>

<!-- ── HEADER ── -->
<div class="page-header">
    <span class="tag">A minha coleção</span>
    <h1>Os meus <span>Favoritos</span></h1>
</div>

<!-- ── CONTENT ── -->
<div class="content-wrap">

    <div class="section-header">
        <h2 class="section-title">Receitas guardadas</h2>
        <span class="section-count">@Model.Favorites.Count() receita(s)</span>
    </div>

    @if (!Model.Favorites.Any())
    {
        <div class="empty-state">
            <div class="emoji">🤍</div>
            <h3>Ainda não tens favoritos</h3>
            <p>Explora as receitas e guarda as que mais gostas!</p>
            <a href="/Recipes/Index" class="btn-explore">Explorar Receitas →</a>
        </div>
    }
    else
    {
        <div class="recipe-grid">
            @foreach (var fav in Model.Favorites)
            {
                var recipe = fav.Recipe;
                <div class="recipe-card">
                    <a href="/Recipes/Detail?id=@recipe.Id" class="card-link">
                        <div class="card-img">
                            🍲
                            <span class="card-badge">@recipe.Difficulty?.Level</span>
                        </div>
                        <div class="card-body">
                            <p class="card-category">@recipe.Category?.Name</p>
                            <h3 class="card-title">@recipe.Name</h3>
                            <p class="card-desc">@recipe.Description</p>
                            <div class="card-footer">
                                <div class="card-meta">
                                    <span>⏱ @recipe.PreparationTime min</span>
                                    <span>👤 @recipe.User?.Name</span>
                                </div>
                            </div>
                        </div>
                    </a>
                    <!-- Remove from favorites -->
                    <div style="padding: 0 1.2rem 1rem; display:flex; justify-content:flex-end;">
                        <form method="post" asp-page-handler="Remove">
                            <input type="hidden" name="recipeId" value="@recipe.Id" />
                            <button type="submit" class="btn-unfavorite">✕ Remover</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
