@page
@model Tempero_do_Dragao.Pages.Recipes.IndexModel
@{
    ViewData["Title"] = "Receitas";
}

<style>
    :root {
        --red-deep: #8B0000;
        --red-mid: #A31515;
        --cream: #F5ECD7;
        --gold: #C9A84C;
        --charcoal: #1A1A1A;
    }

    body {
        background: #faf7f2;
    }

    /* ── HERO ── */
    .hero {
        background: var(--red-deep);
        padding: 4rem 2rem 5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 50% 0%, rgba(192,57,43,0.5) 0%, transparent 70%);
        }

    .hero-deco {
        position: absolute;
        font-size: 12rem;
        font-weight: 900;
        color: rgba(201,168,76,0.05);
        font-family: serif;
        line-height: 1;
        top: 0;
        left: 2rem;
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-tag {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold);
        border: 1px solid rgba(201,168,76,0.4);
        padding: 0.3rem 0.9rem;
        border-radius: 2px;
        margin-bottom: 1rem;
    }

    .hero h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900;
        color: var(--cream);
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 0.95;
        margin-bottom: 1rem;
    }

        .hero h1 span {
            color: var(--gold);
        }

    .hero p {
        font-size: 0.95rem;
        color: rgba(245,236,215,0.6);
        font-weight: 300;
        max-width: 400px;
        margin: 0 auto 2rem;
        line-height: 1.7;
    }

    /* ── SEARCH BAR ── */
    .search-wrap {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        max-width: 500px;
        margin: 0 auto;
    }

        .search-wrap input {
            flex: 1;
            padding: 0.85rem 1.2rem;
            border: none;
            border-radius: 6px 0 0 6px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            outline: none;
            background: rgba(245,236,215,0.95);
            color: var(--charcoal);
        }

        .search-wrap button {
            padding: 0.85rem 1.5rem;
            background: var(--gold);
            color: var(--charcoal);
            border: none;
            border-radius: 0 6px 6px 0;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.82rem;
            font-weight: 500;
            letter-spacing: 0.1em;
            cursor: pointer;
            transition: background 0.2s;
        }

            .search-wrap button:hover {
                background: #e8c56a;
            }

    /* ── FILTERS ── */
    .filters-bar {
        background: white;
        border-bottom: 1px solid #ede8e0;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        overflow-x: auto;
        position: sticky;
        top: 64px;
        z-index: 90;
    }

    .filter-label {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #999;
        white-space: nowrap;
        padding: 1rem 0;
    }

    .filter-btn {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem;
        font-weight: 400;
        color: #666;
        background: none;
        border: none;
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.2s;
    }

        .filter-btn:hover, .filter-btn.active {
            background: var(--red-deep);
            color: var(--cream);
        }

    /* ── MAIN CONTENT ── */
    .content-wrap {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--charcoal);
    }

    .section-count {
        font-size: 0.8rem;
        color: #999;
        font-weight: 300;
    }

    /* ── ADD BUTTON ── */
    .btn-add {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--red-deep);
        color: var(--cream);
        text-decoration: none;
        padding: 0.6rem 1.2rem;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        transition: background 0.2s, transform 0.1s;
    }

        .btn-add:hover {
            background: var(--red-mid);
            transform: translateY(-1px);
            color: var(--cream);
        }

    /* ── RECIPE GRID ── */
    .recipe-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    /* ── RECIPE CARD ── */
    .recipe-card {
        background: white;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .recipe-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        }

    .card-img {
        width: 100%;
        height: 180px;
        background: linear-gradient(135deg, var(--red-deep), var(--red-mid));
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        position: relative;
        overflow: hidden;
    }

        .card-img::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.2));
        }

    .card-badge {
        position: absolute;
        top: 0.8rem;
        right: 0.8rem;
        background: var(--gold);
        color: var(--charcoal);
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border-radius: 3px;
        z-index: 2;
    }

    .card-body {
        padding: 1.2rem;
    }

    .card-category {
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--red-mid);
        margin-bottom: 0.4rem;
    }

    .card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--charcoal);
        margin-bottom: 0.4rem;
        line-height: 1.3;
    }

    .card-desc {
        font-size: 0.82rem;
        color: #888;
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.8rem;
        border-top: 1px solid #f0ece6;
    }

    .card-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.75rem;
        color: #aaa;
    }

        .card-meta span {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

    .card-rating {
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--gold);
    }

    /* ── EMPTY STATE ── */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: #bbb;
    }

        .empty-state .emoji {
            font-size: 4rem;
            margin-bottom: 1rem;
        }

        .empty-state h3 {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            color: #ccc;
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            font-size: 0.88rem;
            font-weight: 300;
        }
</style>

<!-- ── HERO ── -->
<div class="hero">
    <div class="hero-deco">味</div>
    <div class="hero-content">
        <span class="hero-tag">🐉 Tempero do Dragão</span>
        <h1>Descobre as<br><span>melhores receitas</span></h1>
        <p>Explora receitas autênticas criadas pela nossa comunidade de cozinheiros.</p>

        <form method="get" class="search-wrap">
            <input type="text" name="search" value="@Model.Search" placeholder="Pesquisa uma receita..." />
            <button type="submit">Pesquisar</button>
        </form>
    </div>
</div>

<!-- ── FILTERS ── -->
<div class="filters-bar">
    <span class="filter-label">Filtrar:</span>
    <a href="?difficulty=" class="filter-btn @(string.IsNullOrEmpty(Model.Difficulty) ? "active" : "")">Todas</a>
    @foreach (var diff in Model.Difficulties)
    {
        <a href="?difficulty=@diff.Id" class="filter-btn @(Model.Difficulty == diff.Id.ToString() ? "active" : "")">
            @diff.Level
        </a>
    }
</div>

<!-- ── CONTENT ── -->
<div class="content-wrap">
    <div class="section-header">
        <h2 class="section-title">
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <span>Resultados para "@Model.Search"</span>
            }
            else
            {
                <span>Todas as Receitas</span>
            }
        </h2>

        <div style="display:flex; align-items:center; gap:1rem;">
            <span class="section-count">@Model.Recipes.Count() receita(s)</span>

            @if (HttpContext.Session.GetInt32("UserId") != null)
            {
                <a href="/Recipes/Create" class="btn-add">+ Nova Receita</a>
            }
        </div>
    </div>

    @if (!Model.Recipes.Any())
    {
        <div class="empty-state">
            <div class="emoji">🍽️</div>
            <h3>Nenhuma receita encontrada</h3>
            <p>Tenta uma pesquisa diferente ou adiciona a primeira receita!</p>
        </div>
    }
    else
    {
        <div class="recipe-grid">
            @foreach (var recipe in Model.Recipes)
            {
                <a href="/Recipes/Detail?id=@recipe.Id" class="recipe-card">
                    <div class="card-img">
                        🍲
                        <span class="card-badge">@recipe.Difficulty?.Level</span>
                    </div>
                    <div class="card-body">
                        <p class="card-category">@recipe.Category?.Name</p>
                        <h3 class="card-title">@recipe.Name</h3>
                        <p class="card-desc">@recipe.Description</p>
                        <div class="card-footer">
                            <div class="card-meta">
                                <span>⏱ @recipe.PreparationTime min</span>
                                <span>👤 @recipe.User?.Name</span>
                            </div>
                            @if (recipe.Ratings.Any())
                            {
                                <span class="card-rating">
                                    ⭐ @recipe.Ratings.Average(r => r.Score).ToString("0.0")
                                </span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>
