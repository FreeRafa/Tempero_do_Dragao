<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Tempero do Dragão</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --red-deep: #8B0000;
                --red-mid: #A31515;
                --cream: #F5ECD7;
                --gold: #C9A84C;
                --charcoal: #1A1A1A;
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: #faf7f2;
                color: var(--charcoal);
                min-height: 100vh;
            }

            /* ── NAVBAR ── */
            nav {
                background: var(--red-deep);
                padding: 0 2rem;
                display: flex;
                align-items: center;
                justify-content: space-between;
                height: 64px;
                position: sticky;
                top: 0;
                z-index: 100;
                box-shadow: 0 2px 20px rgba(0,0,0,0.3);
            }

            .nav-brand {
                font-family: 'Playfair Display', serif;
                font-size: 1.4rem;
                font-weight: 900;
                color: var(--cream);
                text-decoration: none;
                text-transform: uppercase;
                letter-spacing: -0.01em;
            }

                .nav-brand span {
                    color: var(--gold);
                }

            .nav-links {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                list-style: none;
            }

                .nav-links a {
                    font-size: 0.82rem;
                    font-weight: 400;
                    color: rgba(245,236,215,0.75);
                    text-decoration: none;
                    padding: 0.4rem 0.8rem;
                    border-radius: 4px;
                    letter-spacing: 0.05em;
                    transition: color 0.2s, background 0.2s;
                }

                    .nav-links a:hover {
                        color: var(--cream);
                        background: rgba(255,255,255,0.08);
                    }

                .nav-links .btn-login {
                    color: var(--gold);
                    border: 1px solid rgba(201,168,76,0.4);
                    padding: 0.4rem 1rem;
                }

                    .nav-links .btn-login:hover {
                        background: rgba(201,168,76,0.1);
                        border-color: var(--gold);
                    }

                .nav-links .btn-register {
                    background: var(--gold);
                    color: var(--charcoal);
                    font-weight: 500;
                    padding: 0.4rem 1rem;
                }

                    .nav-links .btn-register:hover {
                        background: #e8c56a;
                        color: var(--charcoal);
                    }

                .nav-links .btn-logout {
                    color: rgba(245,236,215,0.5);
                    font-size: 0.78rem;
                }

            .nav-user {
                color: rgba(245,236,215,0.6);
                font-size: 0.8rem;
                padding: 0.4rem 0.6rem;
            }

            /* ── PAGE CONTENT ── */
            main {
                padding: 2rem;
            }
    </style>
</head>
<body>

    <nav>
        <a class="nav-brand" href="/Recipes/Index">🐉 Tempero <span>do Dragão</span></a>

        <ul class="nav-links">
            <li><a href="/Recipes/Index">Receitas</a></li>

            @if (Context.Session.GetInt32("UserId") != null)
            {
                <!-- Utilizador autenticado -->
                <li><a href="/Recipes/Favorites">Favoritos</a></li>

                @if (Context.Session.GetString("IsAdmin") == "True")
                {
                    <li><a href="/Admin/Index">Admin</a></li>
                }

                <li>
                    <span class="nav-user">
                        👤 @Context.Session.GetString("UserName")
                    </span>
                </li>
                <li><a href="/Auth/Logout" class="btn-logout">Sair</a></li>
            }
            else
            {
                <!-- Visitante -->
                <li><a href="/Auth/Login" class="btn-login">Login</a></li>
                <li><a href="/Auth/Register" class="btn-register">Cadastro</a></li>
            }
        </ul>
    </nav>

    <main>
        @RenderBody()
    </main>

</body>
</html>