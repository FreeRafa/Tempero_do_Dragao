@page
@model Tempero_do_Dragao.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Painel Admin";
}

<style>
    :root {
        --red-deep:  #8B0000;
        --red-mid:   #A31515;
        --cream:     #F5ECD7;
        --cream-dark:#E8D9C0;
        --gold:      #C9A84C;
        --charcoal:  #1A1A1A;
    }

    body { background: #faf7f2; }

    .page-header {
        background: var(--red-deep);
        padding: 2.5rem 2rem;
        position: relative;
        overflow: hidden;
    }

    .page-header::before {
        content: '⚙️';
        position: absolute;
        right: 3rem; top: 50%;
        transform: translateY(-50%);
        font-size: 8rem;
        opacity: 0.08;
    }

    .page-header .tag {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold);
        border: 1px solid rgba(201,168,76,0.4);
        padding: 0.3rem 0.9rem;
        border-radius: 2px;
        margin-bottom: 0.8rem;
    }

    .page-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--cream);
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    .page-header h1 span { color: var(--gold); }

    .content-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.2rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: white;
        border-radius: 10px;
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .stat-icon {
        font-size: 2rem;
        width: 56px;
        height: 56px;
        background: #faf7f2;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .stat-num {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--charcoal);
        line-height: 1;
    }

    .stat-label {
        font-size: 0.75rem;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-top: 0.2rem;
    }

    .btn-data {
        display: inline-block;
        padding: 0.6rem 1.2rem;
        background: var(--gold);
        color: var(--charcoal);
        text-decoration: none;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 500;
        margin-bottom: 1.5rem;
        transition: background 0.2s;
    }

    .btn-data:hover { background: #e8c56a; color: var(--charcoal); }

    .tabs {
        display: flex;
        gap: 0;
        border-bottom: 2px solid #ede8e0;
        margin-bottom: 1.5rem;
    }

    .tab-btn {
        padding: 0.8rem 1.5rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        color: #aaa;
        background: none;
        border: none;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.2s;
    }

    .tab-btn.active {
        color: var(--red-deep);
        border-bottom-color: var(--red-deep);
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    .table-wrap {
        background: white;
        border-radius: 10px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .table-header {
        padding: 1.2rem 1.5rem;
        border-bottom: 1px solid #f0ece6;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .table-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--charcoal);
    }

    table { width: 100%; border-collapse: collapse; }

    th {
        padding: 0.8rem 1.5rem;
        text-align: left;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #aaa;
        background: #faf7f2;
        border-bottom: 1px solid #f0ece6;
    }

    td {
        padding: 1rem 1.5rem;
        font-size: 0.88rem;
        color: var(--charcoal);
        border-bottom: 1px solid #f9f6f2;
        vertical-align: middle;
    }

    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fdfaf7; }

    .badge {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        border-radius: 3px;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.08em;
    }

    .badge-admin   { background: rgba(139,0,0,0.1); color: var(--red-deep); }
    .badge-user    { background: #f0f0f0; color: #888; }
    .badge-active  { background: rgba(39,174,96,0.1); color: #27ae60; }
    .badge-inactive{ background: #f0f0f0; color: #aaa; }

    .action-btns { display: flex; gap: 0.4rem; }

    .btn-action {
        padding: 0.3rem 0.7rem;
        border-radius: 4px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
    }

    .btn-delete { background: #ffebee; color: var(--red-mid); }
    .btn-delete:hover { background: #ffcdd2; }
    .btn-toggle { background: #e8f5e9; color: #27ae60; }
    .btn-toggle:hover { background: #c8e6c9; }

    .btn-view {
        background: #e3f2fd;
        color: #1976d2;
        text-decoration: none;
        display: inline-block;
        padding: 0.3rem 0.7rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .btn-view:hover { background: #bbdefb; }
</style>

<!-- ── HEADER ── -->
<div class="page-header">
    <span class="tag">Administração</span>
    <h1>Painel <span>Admin</span></h1>
</div>

<div class="content-wrap">

    <!-- ── STATS ── -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">👥</div>
            <div>
                <div class="stat-num">@Model.TotalUsers</div>
                <div class="stat-label">Utilizadores</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">🍲</div>
            <div>
                <div class="stat-num">@Model.TotalRecipes</div>
                <div class="stat-label">Receitas</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">💬</div>
            <div>
                <div class="stat-num">@Model.TotalComments</div>
                <div class="stat-label">Comentários</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">⭐</div>
            <div>
                <div class="stat-num">@Model.TotalRatings</div>
                <div class="stat-label">Avaliações</div>
            </div>
        </div>
    </div>

    <!-- ── BOTÃO GERIR DADOS ── -->
    <a href="/Admin/Data" class="btn-data">🗂️ Gerir Dados</a>

    <!-- ── TABS ── -->
    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('users', this)">👥 Utilizadores</button>
        <button class="tab-btn" onclick="switchTab('recipes', this)">🍲 Receitas</button>
    </div>

    <!-- ── USERS TAB ── -->
    <div id="tab-users" class="tab-content active">
        <div class="table-wrap">
            <div class="table-header">
                <span class="table-title">Todos os Utilizadores</span>
                <span style="font-size:0.78rem; color:#aaa;">@Model.Users.Count() registados</span>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td style="color:#bbb;">#@user.Id</td>
                            <td><strong>@user.Name</strong></td>
                            <td style="color:#888;">@user.Email</td>
                            <td>
                                <span class="badge @(user.IsAdmin ? "badge-admin" : "badge-user")">
                                    @(user.IsAdmin ? "Admin" : "Utilizador")
                                </span>
                            </td>
                            <td>
                                <span class="badge @(user.Status == 1 ? "badge-active" : "badge-inactive")">
                                    @(user.Status == 1 ? "Ativo" : "Inativo")
                                </span>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <form method="post" asp-page-handler="ToggleUserStatus" style="display:inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn-action btn-toggle">
                                            @(user.Status == 1 ? "Desativar" : "Ativar")
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="DeleteUser" style="display:inline"
                                          onsubmit="return confirm('Tens a certeza que queres apagar este utilizador?')">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn-action btn-delete">Apagar</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- ── RECIPES TAB ── -->
    <div id="tab-recipes" class="tab-content">
        <div class="table-wrap">
            <div class="table-header">
                <span class="table-title">Todas as Receitas</span>
                <span style="font-size:0.78rem; color:#aaa;">@Model.Recipes.Count() receitas</span>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Autor</th>
                        <th>Categoria</th>
                        <th>Data</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var recipe in Model.Recipes)
                    {
                        <tr>
                            <td style="color:#bbb;">#@recipe.Id</td>
                            <td><strong>@recipe.Name</strong></td>
                            <td style="color:#888;">@recipe.User?.Name</td>
                            <td>@recipe.Category?.Name</td>
                            <td style="color:#bbb; font-size:0.78rem;">@recipe.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <div class="action-btns">
                                    <a href="/Recipes/Detail?id=@recipe.Id" class="btn-view">Ver</a>
                                    <form method="post" asp-page-handler="DeleteRecipe" style="display:inline"
                                          onsubmit="return confirm('Tens a certeza que queres apagar esta receita?')">
                                        <input type="hidden" name="recipeId" value="@recipe.Id" />
                                        <button type="submit" class="btn-action btn-delete">Apagar</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

<script>
    function switchTab(tab, btn) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + tab).classList.add('active');
        btn.classList.add('active');
    }
</script>
