@page
@model Tempero_do_Dragao.Pages.Admin.DataModel
@{
    ViewData["Title"] = "Gestão de Dados";
}

<style>
    :root {
        --red-deep:  #8B0000;
        --red-mid:   #A31515;
        --cream:     #F5ECD7;
        --cream-dark:#E8D9C0;
        --gold:      #C9A84C;
        --charcoal:  #1A1A1A;
    }

    body { background: #faf7f2; }

    .page-header {
        background: var(--red-deep);
        padding: 2.5rem 2rem;
        position: relative;
        overflow: hidden;
    }

    .page-header::before {
        content: '🗂️';
        position: absolute;
        right: 3rem; top: 50%;
        transform: translateY(-50%);
        font-size: 8rem;
        opacity: 0.08;
    }

    .page-header .tag {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--gold);
        border: 1px solid rgba(201,168,76,0.4);
        padding: 0.3rem 0.9rem;
        border-radius: 2px;
        margin-bottom: 0.8rem;
    }

    .page-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--cream);
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    .page-header h1 span { color: var(--gold); }

    /* ── BREADCRUMB ── */
    .breadcrumb {
        padding: 0.8rem 2rem;
        background: white;
        border-bottom: 1px solid #ede8e0;
        font-size: 0.82rem;
        color: #aaa;
    }

    .breadcrumb a { color: var(--red-mid); text-decoration: none; }
    .breadcrumb a:hover { text-decoration: underline; }

    /* ── CONTENT ── */
    .content-wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 2rem;
    }

    /* ── TABS ── */
    .tabs {
        display: flex;
        gap: 0;
        border-bottom: 2px solid #ede8e0;
        margin-bottom: 1.5rem;
        overflow-x: auto;
    }

    .tab-btn {
        padding: 0.8rem 1.5rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 500;
        color: #aaa;
        background: none;
        border: none;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .tab-btn.active {
        color: var(--red-deep);
        border-bottom-color: var(--red-deep);
    }

    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* ── SECTION LAYOUT ── */
    .section-grid {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.5rem;
        align-items: start;
    }

    /* ── TABLE ── */
    .table-wrap {
        background: white;
        border-radius: 10px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .table-header {
        padding: 1.2rem 1.5rem;
        border-bottom: 1px solid #f0ece6;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .table-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--charcoal);
    }

    table { width: 100%; border-collapse: collapse; }

    th {
        padding: 0.8rem 1.5rem;
        text-align: left;
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #aaa;
        background: #faf7f2;
        border-bottom: 1px solid #f0ece6;
    }

    td {
        padding: 0.9rem 1.5rem;
        font-size: 0.88rem;
        color: var(--charcoal);
        border-bottom: 1px solid #f9f6f2;
        vertical-align: middle;
    }

    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fdfaf7; }

    /* ── FORM CARD ── */
    .form-card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        padding: 1.5rem;
        position: sticky;
        top: 80px;
    }

    .form-card-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--charcoal);
        margin-bottom: 1.2rem;
        padding-bottom: 0.8rem;
        border-bottom: 2px solid #f0ece6;
    }

    .field { margin-bottom: 1rem; }

    .field label {
        display: block;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--charcoal);
        margin-bottom: 0.4rem;
    }

    .field input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1.5px solid var(--cream-dark);
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem;
        color: var(--charcoal);
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .field input:focus {
        border-color: var(--gold);
        box-shadow: 0 0 0 3px rgba(201,168,76,0.15);
    }

    .btn-submit {
        width: 100%;
        padding: 0.8rem;
        background: var(--red-deep);
        color: var(--cream);
        border: none;
        border-radius: 6px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-submit:hover { background: var(--red-mid); }

    /* ── ACTION BUTTONS ── */
    .action-btns { display: flex; gap: 0.4rem; }

    .btn-delete {
        padding: 0.3rem 0.7rem;
        background: #ffebee;
        color: var(--red-mid);
        border: none;
        border-radius: 4px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s;
    }

    .btn-delete:hover { background: #ffcdd2; }

    /* ── ALERT ── */
    .alert-success {
        background: rgba(39,174,96,0.08);
        border-left: 3px solid #27ae60;
        color: #1a5c35;
        padding: 0.7rem 1rem;
        font-size: 0.82rem;
        border-radius: 4px;
        margin-bottom: 1rem;
    }

    @@media (max-width: 768px) {
        .section-grid { grid-template-columns: 1fr; }
    }
</style>

<!-- ── HEADER ── -->
<div class="page-header">
    <span class="tag">Administração</span>
    <h1>Gestão de <span>Dados</span></h1>
</div>

<!-- ── BREADCRUMB ── -->
<div class="breadcrumb">
    <a href="/Admin/Index">← Painel Admin</a> / Gestão de Dados
</div>

<div class="content-wrap">

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert-success">✓ @Model.SuccessMessage</div>
    }

    <!-- ── TABS ── -->
    <div class="tabs">
        <button class="tab-btn active" onclick="switchTab('categories', this)">📂 Categorias</button>
        <button class="tab-btn" onclick="switchTab('difficulties', this)">📊 Dificuldades</button>
        <button class="tab-btn" onclick="switchTab('ingredients', this)">🧂 Ingredientes</button>
        <button class="tab-btn" onclick="switchTab('measurements', this)">⚖️ Medidas</button>
    </div>

    <!-- ── CATEGORIES ── -->
    <div id="tab-categories" class="tab-content active">
        <div class="section-grid">
            <div class="table-wrap">
                <div class="table-header">
                    <span class="table-title">Categorias</span>
                    <span style="font-size:0.78rem; color:#aaa;">@Model.Categories.Count() registadas</span>
                </div>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Nome</th><th>Ações</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Categories)
                        {
                            <tr>
                                <td style="color:#bbb;">#@item.Id</td>
                                <td><strong>@item.Name</strong></td>
                                <td>
                                    <form method="post" asp-page-handler="DeleteCategory"
                                          onsubmit="return confirm('Apagar esta categoria?')">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-delete">Apagar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="form-card">
                <h3 class="form-card-title">➕ Nova Categoria</h3>
                <form method="post" asp-page-handler="AddCategory">
                    <div class="field">
                        <label>Nome</label>
                        <input type="text" name="name" placeholder="Ex: Sopas" required />
                    </div>
                    <button type="submit" class="btn-submit">Adicionar</button>
                </form>
            </div>
        </div>
    </div>

    <!-- ── DIFFICULTIES ── -->
    <div id="tab-difficulties" class="tab-content">
        <div class="section-grid">
            <div class="table-wrap">
                <div class="table-header">
                    <span class="table-title">Dificuldades</span>
                    <span style="font-size:0.78rem; color:#aaa;">@Model.Difficulties.Count() registadas</span>
                </div>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Nível</th><th>Ações</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Difficulties)
                        {
                            <tr>
                                <td style="color:#bbb;">#@item.Id</td>
                                <td><strong>@item.Level</strong></td>
                                <td>
                                    <form method="post" asp-page-handler="DeleteDifficulty"
                                          onsubmit="return confirm('Apagar esta dificuldade?')">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-delete">Apagar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="form-card">
                <h3 class="form-card-title">➕ Nova Dificuldade</h3>
                <form method="post" asp-page-handler="AddDifficulty">
                    <div class="field">
                        <label>Nível</label>
                        <input type="text" name="level" placeholder="Ex: Fácil" required />
                    </div>
                    <button type="submit" class="btn-submit">Adicionar</button>
                </form>
            </div>
        </div>
    </div>

    <!-- ── INGREDIENTS ── -->
    <div id="tab-ingredients" class="tab-content">
        <div class="section-grid">
            <div class="table-wrap">
                <div class="table-header">
                    <span class="table-title">Ingredientes</span>
                    <span style="font-size:0.78rem; color:#aaa;">@Model.Ingredients.Count() registados</span>
                </div>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Nome</th><th>Ações</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Ingredients)
                        {
                            <tr>
                                <td style="color:#bbb;">#@item.Id</td>
                                <td><strong>@item.Name</strong></td>
                                <td>
                                    <form method="post" asp-page-handler="DeleteIngredient"
                                          onsubmit="return confirm('Apagar este ingrediente?')">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-delete">Apagar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="form-card">
                <h3 class="form-card-title">➕ Novo Ingrediente</h3>
                <form method="post" asp-page-handler="AddIngredient">
                    <div class="field">
                        <label>Nome</label>
                        <input type="text" name="name" placeholder="Ex: Batata" required />
                    </div>
                    <button type="submit" class="btn-submit">Adicionar</button>
                </form>
            </div>
        </div>
    </div>

    <!-- ── MEASUREMENTS ── -->
    <div id="tab-measurements" class="tab-content">
        <div class="section-grid">
            <div class="table-wrap">
                <div class="table-header">
                    <span class="table-title">Unidades de Medida</span>
                    <span style="font-size:0.78rem; color:#aaa;">@Model.Measurements.Count() registadas</span>
                </div>
                <table>
                    <thead>
                        <tr><th>ID</th><th>Unidade</th><th>Ações</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Measurements)
                        {
                            <tr>
                                <td style="color:#bbb;">#@item.Id</td>
                                <td><strong>@item.Unit</strong></td>
                                <td>
                                    <form method="post" asp-page-handler="DeleteMeasurement"
                                          onsubmit="return confirm('Apagar esta medida?')">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-delete">Apagar</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="form-card">
                <h3 class="form-card-title">➕ Nova Medida</h3>
                <form method="post" asp-page-handler="AddMeasurement">
                    <div class="field">
                        <label>Unidade</label>
                        <input type="text" name="unit" placeholder="Ex: kg" required />
                    </div>
                    <button type="submit" class="btn-submit">Adicionar</button>
                </form>
            </div>
        </div>
    </div>

</div>

<script>
    function switchTab(tab, btn) {
        document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + tab).classList.add('active');
        btn.classList.add('active');
    }
</script>
